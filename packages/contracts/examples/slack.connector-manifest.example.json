{
  "contract_version": "hadesos.contracts.v1",
  "schema_version": "1.0.0",
  "schema_name": "connector-manifest",
  "connector_id": "slack",
  "name": "Slack",
  "description": "Slack drafting and channel summary connector",
  "publisher": "Luca Dynamics",
  "manifest_version": "1.0.0",
  "status": "active",
  "execution_modes": [
    "local_first"
  ],
  "data_classifications": [
    "business_sensitive"
  ],
  "capabilities": [
    {
      "capability_id": "messages.summarize",
      "description": "Summarize messages in approved synthetic channels",
      "risk_class": "sensitive_read",
      "data_classification": "business_sensitive",
      "scopes": [
        "slack.channels.history"
      ],
      "actions": [
        "summarize_channel"
      ],
      "requires_approval": false,
      "rollback_supported": false
    },
    {
      "capability_id": "messages.draft",
      "description": "Draft a message for human review without sending",
      "risk_class": "draft",
      "data_classification": "business_sensitive",
      "scopes": [
        "slack.messages.draft"
      ],
      "actions": [
        "draft_message"
      ],
      "requires_approval": true,
      "rollback_supported": true
    }
  ],
  "auth": {
    "type": "oauth_or_local_permission",
    "token_storage": "not_in_manifest"
  },
  "audit_events": [
    "proposal_created",
    "approval_requested",
    "action_executed"
  ],
  "fixtures": [
    "fixtures/slack.synthetic.json"
  ]
}
