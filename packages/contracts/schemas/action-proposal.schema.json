{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.hadesos.local/contracts/v1/action-proposal.schema.json",
  "title": "HadesOS Action Proposal",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "contract_version": {
      "type": "string",
      "const": "hadesos.contracts.v1"
    },
    "schema_name": {
      "type": "string",
      "const": "action-proposal"
    },
    "schema_version": {
      "type": "string",
      "pattern": "^1\\.0\\.0$"
    },
    "proposal_id": {
      "type": "string",
      "minLength": 1
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "requested_by": {
      "enum": [
        "user",
        "automation",
        "agent",
        "system"
      ]
    },
    "requester": {
      "type": "object",
      "additionalProperties": true
    },
    "connector_id": {
      "type": "string",
      "minLength": 1
    },
    "capability": {
      "type": "string",
      "minLength": 1
    },
    "action": {
      "type": "string",
      "minLength": 1
    },
    "target": {
      "type": "object",
      "additionalProperties": true
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "reason": {
      "type": "string",
      "minLength": 1
    },
    "risk_class": {
      "enum": [
        "observe",
        "sensitive_read",
        "draft",
        "reversible_write",
        "external_send",
        "privileged_change",
        "physical_control",
        "forbidden"
      ]
    },
    "data_classification": {
      "enum": [
        "public",
        "personal",
        "confidential",
        "business_sensitive",
        "regulated",
        "physical_environment_sensitive"
      ]
    },
    "execution_mode": {
      "enum": [
        "local_only",
        "cloud_only",
        "local_first",
        "cloud_brokered",
        "enterprise_private"
      ]
    },
    "scopes_required": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "inputs": {
      "type": "object",
      "additionalProperties": true
    },
    "preview": {
      "type": "object",
      "additionalProperties": true
    },
    "requires_approval": {
      "type": "boolean"
    },
    "rollback_required": {
      "type": "boolean"
    },
    "rollback_metadata_ref": {
      "type": [
        "string",
        "null"
      ]
    },
    "expires_at": {
      "type": "string",
      "format": "date-time"
    },
    "correlation_id": {
      "type": "string",
      "minLength": 1
    }
  },
  "required": [
    "contract_version",
    "schema_name",
    "schema_version",
    "proposal_id",
    "created_at",
    "requested_by",
    "connector_id",
    "capability",
    "action",
    "target",
    "summary",
    "reason",
    "risk_class",
    "data_classification",
    "execution_mode",
    "scopes_required",
    "requires_approval",
    "rollback_required",
    "expires_at",
    "correlation_id"
  ]
}
